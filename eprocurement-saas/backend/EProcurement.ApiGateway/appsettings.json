{
  "Frontend": {
    "Url": "http://localhost:3000"
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/auth/{**catch-all}" }
        ]
      },
      "tenants": {
        "ClusterId": "tenants",
        "Match": {
          "Path": "/tenants/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/tenants/{**catch-all}" }
        ]
      },
      "users": {
        "ClusterId": "auth",
        "Match": {
          "Path": "/users/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/users/{**catch-all}" }
        ]
      },
      "roles": {
        "ClusterId": "auth",
        "Match": {
          "Path": "/roles/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/roles/{**catch-all}" }
        ]
      },
      "masterData": {
        "ClusterId": "tenants",
        "Match": {
          "Path": "/master-data/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/master-data/{**catch-all}" }
        ]
      },
      "vendors": {
        "ClusterId": "vendors",
        "Match": { "Path": "/vendors/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/vendors/{**catch-all}" } ]
      },
      "purchaseRequests": {
        "ClusterId": "procurement",
        "Match": { "Path": "/purchase-requests/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/purchase-requests/{**catch-all}" } ]
      },
      "approvalMatrix": {
        "ClusterId": "procurement",
        "Match": { "Path": "/approval-matrix/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/approval-matrix/{**catch-all}" } ]
      },
      "tenders": {
        "ClusterId": "tenders",
        "Match": { "Path": "/tenders/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/tenders/{**catch-all}" } ]
      },
      "bids": {
        "ClusterId": "bidding",
        "Match": { "Path": "/bids/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/bids/{**catch-all}" } ]
      },
      "awards": {
        "ClusterId": "contracts",
        "Match": { "Path": "/awards/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/awards/{**catch-all}" } ]
      },
      "purchaseOrders": {
        "ClusterId": "contracts",
        "Match": { "Path": "/purchase-orders/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/purchase-orders/{**catch-all}" } ]
      },
      "contracts": {
        "ClusterId": "contracts",
        "Match": { "Path": "/contracts/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/contracts/{**catch-all}" } ]
      },
      "documents": {
        "ClusterId": "documents",
        "Match": { "Path": "/documents/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/documents/{**catch-all}" } ]
      },
      "auditLogs": {
        "ClusterId": "audit",
        "Match": { "Path": "/audit-logs/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/audit-logs/{**catch-all}" } ]
      },
      "notifications": {
        "ClusterId": "notifications",
        "Match": { "Path": "/notifications/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/notifications/{**catch-all}" } ]
      },
      "sap": {
        "ClusterId": "sap",
        "Match": { "Path": "/sap/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/sap/{**catch-all}" } ]
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": {
          "auth1": {
            "Address": "http://auth-service:8080"
          }
        }
      },
      "tenants": {
        "Destinations": {
          "tenant1": {
            "Address": "http://tenant-service:8080"
          }
        }
      },
      "vendors": {
        "Destinations": { "vendor1": { "Address": "http://vendor-service:8080" } }
      },
      "procurement": {
        "Destinations": { "procurement1": { "Address": "http://procurement-service:8080" } }
      },
      "tenders": {
        "Destinations": { "tender1": { "Address": "http://tender-service:8080" } }
      },
      "bidding": {
        "Destinations": { "bidding1": { "Address": "http://bidding-service:8080" } }
      },
      "contracts": {
        "Destinations": { "contract1": { "Address": "http://contract-service:8080" } }
      },
      "documents": {
        "Destinations": { "document1": { "Address": "http://document-service:8080" } }
      },
      "audit": {
        "Destinations": { "audit1": { "Address": "http://audit-service:8080" } }
      },
      "notifications": {
        "Destinations": { "notification1": { "Address": "http://notification-service:8080" } }
      },
      "sap": {
        "Destinations": { "sap1": { "Address": "http://sap-integration-service:8080" } }
      }
    }
  }
}
